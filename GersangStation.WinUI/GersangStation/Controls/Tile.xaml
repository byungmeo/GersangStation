<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="GersangStation.Controls.Tile"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:GersangStation.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        x:Name="RootGrid"
        Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource SurfaceStrokeColorFlyoutBrush}"
        CornerRadius="8">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="TileInteractionStates">
                <VisualState x:Name="DefaultNormal" />
                <VisualState x:Name="AccentNormal">
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Background" Value="{ThemeResource AccentButtonBackground}" />
                        <Setter Target="RootGrid.BorderBrush" Value="{ThemeResource AccentButtonBorderBrush}" />
                        <Setter Target="IconGlyph.Foreground" Value="{ThemeResource AccentButtonForeground}" />
                        <Setter Target="SourcePresenter.Foreground" Value="{ThemeResource AccentButtonForeground}" />
                        <Setter Target="TitleText.Foreground" Value="{ThemeResource AccentButtonForeground}" />
                        <Setter Target="DescriptionText.Foreground" Value="{ThemeResource AccentButtonForeground}" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="AccentPointerOver">
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Background" Value="{ThemeResource AccentButtonBackgroundPointerOver}" />
                        <Setter Target="RootGrid.BorderBrush" Value="{ThemeResource AccentButtonBorderBrushPointerOver}" />
                        <Setter Target="IconGlyph.Foreground" Value="{ThemeResource AccentButtonForegroundPointerOver}" />
                        <Setter Target="SourcePresenter.Foreground" Value="{ThemeResource AccentButtonForegroundPointerOver}" />
                        <Setter Target="TitleText.Foreground" Value="{ThemeResource AccentButtonForegroundPointerOver}" />
                        <Setter Target="DescriptionText.Foreground" Value="{ThemeResource AccentButtonForegroundPointerOver}" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="AccentPressed">
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Background" Value="{ThemeResource AccentButtonBackgroundPressed}" />
                        <Setter Target="RootGrid.BorderBrush" Value="{ThemeResource AccentButtonBorderBrushPressed}" />
                        <Setter Target="IconGlyph.Foreground" Value="{ThemeResource AccentButtonForegroundPressed}" />
                        <Setter Target="SourcePresenter.Foreground" Value="{ThemeResource AccentButtonForegroundPressed}" />
                        <Setter Target="TitleText.Foreground" Value="{ThemeResource AccentButtonForegroundPressed}" />
                        <Setter Target="DescriptionText.Foreground" Value="{ThemeResource AccentButtonForegroundPressed}" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <Grid.Resources>
            <ResourceDictionary>
                <ResourceDictionary.ThemeDictionaries>
                    <ResourceDictionary x:Key="Light">
                        <SolidColorBrush x:Key="HyperlinkButtonBorderBrush" Color="{ThemeResource ControlStrokeColorDefault}" />
                        <SolidColorBrush x:Key="HyperlinkButtonBorderBrushPointerOver" Color="{ThemeResource ControlStrokeColorSecondary}" />
                        <SolidColorBrush x:Key="HyperlinkButtonBorderBrushPressed" Color="{ThemeResource ControlStrokeColorDefault}" />
                        <SolidColorBrush x:Key="HyperlinkButtonBorderBrushDisabled" Color="{ThemeResource ControlStrokeColorDefault}" />
                    </ResourceDictionary>
                    <ResourceDictionary x:Key="Dark">
                        <SolidColorBrush x:Key="HyperlinkButtonBorderBrush" Color="{ThemeResource ControlStrokeColorDefault}" />
                        <SolidColorBrush x:Key="HyperlinkButtonBorderBrushPointerOver" Color="{ThemeResource ControlStrokeColorSecondary}" />
                        <SolidColorBrush x:Key="HyperlinkButtonBorderBrushPressed" Color="{ThemeResource ControlStrokeColorDefault}" />
                        <SolidColorBrush x:Key="HyperlinkButtonBorderBrushDisabled" Color="{ThemeResource ControlStrokeColorDefault}" />
                    </ResourceDictionary>
                    <ResourceDictionary x:Key="HighContrast">
                        <SolidColorBrush x:Key="HyperlinkButtonBorderBrush" Color="{ThemeResource SystemColorButtonTextColor}" />
                        <SolidColorBrush x:Key="HyperlinkButtonBorderBrushPointerOver" Color="{ThemeResource SystemColorButtonTextColor}" />
                        <SolidColorBrush x:Key="HyperlinkButtonBorderBrushPressed" Color="{ThemeResource SystemColorButtonTextColor}" />
                        <SolidColorBrush x:Key="HyperlinkButtonBorderBrushDisabled" Color="{ThemeResource SystemColorButtonTextColor}" />
                    </ResourceDictionary>
                </ResourceDictionary.ThemeDictionaries>
            </ResourceDictionary>
        </Grid.Resources>
        <HyperlinkButton
            PointerEntered="HyperlinkButton_PointerEntered"
            PointerExited="HyperlinkButton_PointerExited"
            PointerPressed="HyperlinkButton_PointerPressed"
            PointerReleased="HyperlinkButton_PointerReleased"
            PointerCanceled="HyperlinkButton_PointerCanceled"
            Padding="-1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            AutomationProperties.LabeledBy="{Binding ElementName=TitleText}"
            CornerRadius="{StaticResource OverlayCornerRadius}"
            NavigateUri="{x:Bind Link}">
            <Grid
                Padding="18"
                VerticalAlignment="Stretch"
                RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <FontIcon
                    x:Name="IconGlyph"
                    Grid.RowSpan="3"
                    Margin="-12"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Glyph="&#xE8A7;" />
                <ContentPresenter
                    x:Name="SourcePresenter"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    Content="{x:Bind Source}" />
                <StackPanel
                    Grid.Row="1"
                    Orientation="Vertical"
                    Spacing="4">
                    <TextBlock
                        x:Name="TitleText"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        Text="{x:Bind Title}" />
                    <TextBlock
                        x:Name="DescriptionText"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind Description}" />
                </StackPanel>
            </Grid>
        </HyperlinkButton>
    </Grid>
</UserControl>
