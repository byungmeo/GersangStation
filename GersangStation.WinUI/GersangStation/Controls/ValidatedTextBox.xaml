<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="GersangStation.Controls.ValidatedTextBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:GersangStation.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  Header  -->
            <RowDefinition Height="Auto" />
            <!--  Input Row  -->
            <RowDefinition Height="Auto" />
            <!--  Error  -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!--  Header  -->
        <ContentPresenter
            Grid.Row="0"
            Grid.Column="1"
            Content="{x:Bind Header, Mode=OneWay}"
            Visibility="{x:Bind HeaderVisibility, Mode=OneWay}" />


        <!--  Input Row  -->
        <ContentPresenter
            Grid.Row="1"
            Grid.Column="0"
            VerticalAlignment="Center"
            Content="{x:Bind InputRowLeftContent, Mode=OneWay}" />

        <TextBox
            x:Name="InnerTextBox"
            Grid.Row="1"
            Grid.Column="1"
            VerticalAlignment="Center"
            IsEnabled="{x:Bind InputIsEnabled, Mode=OneWay}"
            PlaceholderText="{x:Bind PlaceholderText, Mode=OneWay}"
            Text="{x:Bind Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            TextChanged="InnerTextBox_TextChanged" />

        <ContentPresenter
            Grid.Row="1"
            Grid.Column="2"
            VerticalAlignment="Center"
            Content="{x:Bind InputRowRightContent, Mode=OneWay}" />

        <!--  Error  -->
        <TextBlock
            x:Name="ErrorTextBlock"
            Grid.Row="2"
            Grid.Column="1"
            Text="{x:Bind ErrorText, Mode=OneWay}"
            TextWrapping="Wrap"
            Visibility="Collapsed" />
    </Grid>
</UserControl>
