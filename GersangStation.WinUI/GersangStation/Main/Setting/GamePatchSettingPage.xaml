<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="GersangStation.Main.Setting.GamePatchSettingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:GersangStation.Main.Setting"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="using:Core.Models"
    d:DataContext="{d:DesignInstance Type=local:GamePatchSettingPage}"
    NavigationCacheMode="Disabled"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <SelectorBar
            x:Name="SelectorBar_Server"
            Grid.Row="0"
            IsEnabled="{x:Bind IsNotBusy, Mode=OneWay}"
            IsHitTestVisible="{x:Bind IsNotBusy, Mode=OneWay}"
            SelectionChanged="SelectorBar_Server_SelectionChanged">
            <SelectorBarItem
                x:Name="SelectorBarItem_Live"
                Tag="{x:Bind model:GameServer.Korea_Live}"
                Text="본섭" />
            <SelectorBarItem
                x:Name="SelectorBarItem_Test"
                Tag="{x:Bind model:GameServer.Korea_Test}"
                Text="테섭" />
            <SelectorBarItem
                x:Name="SelectorBarItem_RnD"
                Tag="{x:Bind model:GameServer.Korea_RnD}"
                Text="천라섭" />
        </SelectorBar>

        <Border
            Grid.Row="0"
            Height="1"
            Margin="0,10,0,0"
            VerticalAlignment="Bottom"
            Background="{ThemeResource ControlStrokeColorDefaultBrush}" />

        <Grid
            Grid.Row="1"
            Margin="10,10,10,10"
            ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--#region Left Contents-->
            <ScrollViewer
                Grid.Column="0"
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled"
                VerticalScrollBarVisibility="Auto"
                VerticalScrollMode="Auto">
                <Grid Padding="0" RowSpacing="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <!--#region Patch Control Row-->
                    <Grid
                        Grid.Row="0"
                        HorizontalAlignment="Stretch"
                        ColumnSpacing="12"
                        RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox
                            x:Name="ComboBox_CurrentVersion"
                            Grid.Row="0"
                            Grid.Column="0"
                            HorizontalAlignment="Stretch"
                            DisplayMemberPath="Display"
                            Header="현재 버전"
                            IsEnabled="{x:Bind IsNotBusy, Mode=OneWay}"
                            ItemsSource="{x:Bind Versions}"
                            PlaceholderText="v00000   0000-00-00"
                            SelectedItem="{x:Bind SelectedVersionItem, Mode=TwoWay}"
                            SelectionChanged="ComboBox_CurrentVersion_SelectionChanged" />
                        <FontIcon
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="0,0,0,8"
                            VerticalAlignment="Bottom"
                            FontSize="32"
                            Glyph="&#xEB9D;" />
                        <TextBox
                            x:Name="TextBox_LatestVersion"
                            Grid.Row="0"
                            Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            Background="{ThemeResource TextBoxDisabledBackgroundThemeBrush}"
                            Header="최신 버전"
                            IsEnabled="{x:Bind IsNotBusy, Mode=OneWay}"
                            IsReadOnly="True"
                            PlaceholderText="v00000   0000-00-00"
                            Text="{x:Bind DisplayLatestVersion, Mode=OneWay}" />
                        <Button
                            x:Name="Button_Refresh"
                            Grid.Row="0"
                            Grid.Column="3"
                            Margin="0,24,0,0"
                            VerticalAlignment="Top"
                            Click="Button_Refresh_Click"
                            IsEnabled="{x:Bind IsNotBusy, Mode=OneWay}"
                            Style="{ThemeResource AlternateCloseButtonStyle}">
                            <Button.Content>
                                <FontIcon Glyph="&#xE895;" />
                            </Button.Content>
                        </Button>
                        <StackPanel
                            Grid.Row="1"
                            Grid.ColumnSpan="4"
                            HorizontalAlignment="Left"
                            Spacing="4"
                            Visibility="{x:Bind VersionWarningVisibility, Mode=OneWay}">
                            <TextBlock
                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                Text="{x:Bind VersionWarningMessage, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                            <HyperlinkButton
                                x:Name="HyperlinkButton_DeprecatedVersionInfo"
                                Padding="0"
                                HorizontalAlignment="Left"
                                Click="HyperlinkButton_DeprecatedVersionInfo_Click"
                                Content="{x:Bind VersionWarningLinkText, Mode=OneWay}"
                                Visibility="{x:Bind VersionWarningLinkVisibility, Mode=OneWay}" />
                        </StackPanel>
                    </Grid>
                    <!--#endregion Patch Control Row-->

                    <!--#region Patch Option Row-->
                    <StackPanel
                        Grid.Row="1"
                        HorizontalAlignment="Stretch"
                        Spacing="10">
                        <CheckBox
                            Content="다클라 패치 적용"
                            IsChecked="{x:Bind ShouldPatchMultiClient, Mode=TwoWay}"
                            IsEnabled="{x:Bind IsNotBusy, Mode=OneWay}" />
                        <CheckBox
                            Content="다클라 설정 파일 덮어쓰기"
                            IsChecked="{x:Bind ShouldOverwriteMultiClientConfig, Mode=TwoWay}"
                            IsEnabled="{x:Bind IsOverwriteMultiClientConfigEnabled, Mode=OneWay}" />
                        <CheckBox
                            Content="(권장) 임시 파일 삭제"
                            IsChecked="{x:Bind ShouldDeleteTemp, Mode=TwoWay}"
                            IsEnabled="{x:Bind IsNotBusy, Mode=OneWay}" />
                        <TextBlock
                            FontSize="12"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind TempPath, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                        <Button
                            x:Name="Button_PatchStart"
                            HorizontalAlignment="Right"
                            Click="Button_PatchStart_Click"
                            Content="패치"
                            IsEnabled="{x:Bind IsPatchStartEnabled, Mode=OneWay}"
                            Style="{ThemeResource AccentButtonStyle}" />
                    </StackPanel>
                    <!--#endregion Patch Option Row-->

                    <!--#region Progress Row-->
                    <Grid
                        Grid.Row="2"
                        HorizontalAlignment="Stretch"
                        RowSpacing="8"
                        Visibility="{x:Bind PatchProgressVisibility, Mode=OneWay}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ProgressBar
                            Grid.Row="0"
                            Grid.Column="0"
                            Height="8"
                            HorizontalAlignment="Stretch"
                            Maximum="{x:Bind ProgressMaximum, Mode=OneWay}"
                            Value="{x:Bind ProgressValue, Mode=OneWay}" />

                        <Button
                            x:Name="Button_PatchStop"
                            Grid.Row="0"
                            Grid.Column="1"
                            Click="Button_PatchStop_Click"
                            IsEnabled="{x:Bind IsDownloading, Mode=OneWay}"
                            Style="{ThemeResource AlternateCloseButtonStyle}"
                            Visibility="{x:Bind PatchCancelVisibility, Mode=OneWay}">
                            <Button.Content>
                                <FontIcon Glyph="&#xE711;" />
                            </Button.Content>
                        </Button>

                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            HorizontalAlignment="Center"
                            Text="{x:Bind ProgressText, Mode=OneWay}"
                            TextAlignment="Center"
                            TextWrapping="WrapWholeWords" />
                    </Grid>
                    <!--#endregion Progress Row-->

                    <!--#region Patch Record Row (향후 개발)-->
                    <!--
        <Grid Grid.Row="3">
            <ListView
                Margin="10,0,10,0"
                BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="1"
                Header="패치이력"
                ItemsSource="{x:Bind PatchRecords, Mode=OneWay}"
                SelectionMode="None">
                <ListViewItem>
                    <TextBlock IsTextSelectionEnabled="True" Text="[2026-03-05 12:00:00 AM] [1m 36s] [성공] v34000 -&gt; v34000" />
                </ListViewItem>
                <ListViewItem>
                    <TextBlock IsTextSelectionEnabled="True" Text="[2026-03-05 12:00:00 AM] [1m 36s] [성공] v34000 -&gt; v34000" />
                </ListViewItem>
                <ListViewItem>
                    <TextBlock IsTextSelectionEnabled="True" Text="[2026-03-05 12:00:00 AM] [1m 36s] [성공] v34000 -&gt; v34000" />
                </ListViewItem>
                <ListViewItem>
                    <TextBlock IsTextSelectionEnabled="True" Text="[2026-03-05 12:00:00 AM] [1m 36s] [성공] v34000 -&gt; v34000" />
                </ListViewItem>
            </ListView>
        </Grid>
                    -->
                    <!--#endregion Patch Record Row-->
                </Grid>
            </ScrollViewer>
            <!--#endregion Left Contents-->

            <Border
                Grid.Row="1"
                Grid.Column="1"
                Width="1"
                HorizontalAlignment="Right"
                Background="{ThemeResource ControlStrokeColorDefaultBrush}" />

            <!--#region Right Contents-->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock
                    Grid.Row="0"
                    VerticalAlignment="Top"
                    Style="{ThemeResource TitleTextBlockStyle}"
                    Text="패치내역" />
                <ScrollView
                    Grid.Row="1"
                    Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
                    HorizontalScrollBarVisibility="Hidden"
                    HorizontalScrollMode="Disabled">
                    <RichTextBlock
                        x:Name="RichTextBlock_PatchReadme"
                        Padding="10,10,10,10"
                        TextAlignment="Justify" />
                </ScrollView>
            </Grid>
            <!--#endregion Right Contents-->
        </Grid>

        <!--#region 로딩 오버레이-->
        <Grid
            x:Name="LoadingOverlay"
            Grid.RowSpan="2"
            Background="{ThemeResource SmokeFillColorDefaultBrush}"
            Visibility="{x:Bind LoadingOverlayVisibility, Mode=OneWay}">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
                <ProgressRing
                    Width="86"
                    Height="86"
                    IsActive="{x:Bind IsLoadingPatchInfo, Mode=OneWay}" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="28"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                    Text="패치 버전 정보를 불러오는 중..." />
            </StackPanel>
        </Grid>
        <!--#endregion 로딩 오버레이-->
    </Grid>
</Page>
