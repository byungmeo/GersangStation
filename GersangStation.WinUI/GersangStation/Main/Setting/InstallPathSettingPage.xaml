<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="GersangStation.Main.Setting.InstallPathSettingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:GersangStation.Main.Setting"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=local:InstallPathSettingPage}"
    NavigationCacheMode="Disabled"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <SelectorBar
            x:Name="GameServerSelectorBar"
            Grid.Row="0"
            SelectionChanged="GameServerSelectorBar_SelectionChanged">
            <SelectorBarItem x:Name="SelectorBarItemPage1" Text="본섭" />
            <SelectorBarItem x:Name="SelectorBarItemPage2" Text="테섭" />
            <SelectorBarItem x:Name="SelectorBarItemPage3" Text="천라섭" />
        </SelectorBar>

        <Border
            Grid.Row="0"
            Height="1"
            Margin="0,10,0,0"
            VerticalAlignment="Bottom"
            Background="{ThemeResource ControlStrokeColorDefaultBrush}" />

        <Frame
            x:Name="ContentFrame"
            Grid.Row="1"
            IsNavigationStackEnabled="False" />
    </Grid>
</Page>
