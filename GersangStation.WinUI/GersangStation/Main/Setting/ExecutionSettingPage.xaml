<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="GersangStation.Main.Setting.ExecutionSettingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:GersangStation.Main.Setting"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=local:ExecutionSettingPage}"
    Loaded="ExecutionSettingPage_Loaded"
    mc:Ignorable="d">

    <Grid>
        <ScrollViewer>
            <StackPanel Padding="24,24,24,40" Spacing="20">
                <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="실행 설정" />

                <Border
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="관리자 권한 바로가기 생성" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="관리자 권한으로 거상스테이션을 실행하는 바로가기를 바탕화면에 만듭니다."
                            TextWrapping="WrapWholeWords" />
                        <Button
                            x:Name="Button_CreateAdminLaunchDesktopShortcut"
                            HorizontalAlignment="Left"
                            Click="Button_CreateAdminLaunchDesktopShortcut_Click"
                            Content="바탕화면에 관리자 실행 바로가기 만들기"
                            Style="{ThemeResource AccentButtonStyle}" />
                    </StackPanel>
                </Border>

                <Border
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="윈도우 시작 자동 실행" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Windows에 로그인할 때 거상스테이션을 자동으로 실행합니다."
                            TextWrapping="WrapWholeWords" />
                        <ToggleSwitch
                            x:Name="ToggleSwitch_StartupRegistration"
                            Header="윈도우 시작 시 프로그램 자동 실행"
                            OffContent="해제"
                            OnContent="등록"
                            Toggled="ToggleSwitch_StartupRegistration_Toggled" />
                        <ToggleSwitch
                            x:Name="ToggleSwitch_StartupRegistrationRunAsAdministrator"
                            Header="자동 실행 시 관리자 권한으로 실행"
                            OffContent="일반 권한"
                            OnContent="관리자 권한"
                            Toggled="ToggleSwitch_StartupRegistrationRunAsAdministrator_Toggled" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="등록 또는 해제 시 Windows 관리자 권한 승인이 필요할 수 있습니다."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Text="{x:Bind ExecutionRegistrationMessage, Mode=OneWay}"
                    TextWrapping="WrapWholeWords"
                    Visibility="{x:Bind ExecutionRegistrationMessageVisibility, Mode=OneWay}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
