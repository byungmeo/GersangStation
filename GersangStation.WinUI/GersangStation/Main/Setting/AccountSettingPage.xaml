<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="GersangStation.Main.Setting.AccountSettingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:GersangStation.Main.Setting"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Core.Models"
    d:DataContext="{d:DesignInstance Type=local:AccountSettingPage}"
    NavigationCacheMode="Disabled"
    mc:Ignorable="d">

    <Page.Resources>
        <CollectionViewSource x:Name="AccountsCVS" IsSourceGrouped="True" />

        <DataTemplate x:Key="AccountListViewTemplate" x:DataType="models:Account">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="12,6,0,0"
                    HorizontalAlignment="Right"
                    Text="아이디:" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="12,0,0,6"
                    HorizontalAlignment="Right"
                    Text="별명:" />

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="12,6,0,0"
                    x:Phase="1"
                    Style="{ThemeResource BaseTextBlockStyle}"
                    Text="{x:Bind Id}" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="12,0,0,6"
                    x:Phase="2"
                    Style="{ThemeResource BodyTextBlockStyle}"
                    Text="{x:Bind DisplayNickname}" />
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid Margin="10,10,10,10" ColumnSpacing="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel
                Grid.Row="0"
                Orientation="Horizontal"
                Spacing="5">
                <Button
                    x:Name="Button_Edit"
                    Click="Button_Edit_Click"
                    Content="수정"
                    IsTabStop="False"
                    IsEnabled="{x:Bind CanEditSelectedAccount, Mode=OneWay}" />
                <Button
                    x:Name="Button_Delete"
                    Click="Button_Delete_Click"
                    Content="삭제"
                    IsTabStop="False"
                    IsEnabled="{x:Bind CanDeleteSelectedAccount, Mode=OneWay}" />
            </StackPanel>
            <ListView
                x:Name="AccountListView"
                Grid.Row="1"
                VerticalAlignment="Top"
                IsEnabled="{x:Bind AccountManagementEnabled, Mode=OneWay}"
                IsTabStop="False"
                ItemTemplate="{StaticResource AccountListViewTemplate}"
                ItemsSource="{x:Bind AccountsCVS.View, Mode=OneWay}"
                SelectionChanged="AccountListView_SelectionChanged"
                SelectionMode="Multiple">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsStackPanel AreStickyGroupHeadersEnabled="True" />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate x:DataType="models:AccountGroupInfoList">
                                <Border AutomationProperties.AccessibilityView="Raw">
                                    <TextBlock
                                        AutomationProperties.AccessibilityView="Raw"
                                        Style="{ThemeResource TitleTextBlockStyle}"
                                        Text="{x:Bind Key}" />
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListView.GroupStyle>
            </ListView>
        </Grid>

        <Border
            Grid.Column="1"
            Width="1"
            HorizontalAlignment="Right"
            Background="{ThemeResource ControlStrokeColorDefaultBrush}" />

        <ScrollViewer
            Grid.Column="2"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto">
            <Grid RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Style="{ThemeResource TitleTextBlockStyle}"
                    Text="{x:Bind EditorTitle, Mode=OneWay}" />
                <TextBox
                    x:Name="TextBox_Id"
                    Grid.Row="1"
                    Header="아이디"
                    KeyDown="EditorInput_KeyDown"
                    PlaceholderText="게임 아이디"
                    TabIndex="0"
                    Text="{x:Bind Editor.Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <StackPanel Grid.Row="2" Spacing="8">
                    <CheckBox
                        x:Name="CheckBox_ChangePassword"
                        Click="CheckBox_ChangePassword_Click"
                        Content="패스워드도 변경"
                        IsChecked="{x:Bind Editor.IsChangingPassword, Mode=OneWay}"
                        IsTabStop="False"
                        Visibility="{x:Bind ChangePasswordToggleVisibility, Mode=OneWay}" />
                    <PasswordBox
                        x:Name="PasswordBox_Pwd"
                        Header="{x:Bind PasswordBoxHeader, Mode=OneWay}"
                        KeyDown="EditorInput_KeyDown"
                        PasswordChanged="PasswordBox_Pwd_PasswordChanged"
                        PlaceholderText="{x:Bind PasswordPlaceholderText, Mode=OneWay}"
                        TabIndex="1"
                        Visibility="{x:Bind PasswordBoxVisibility, Mode=OneWay}" />
                </StackPanel>
                <TextBox
                    x:Name="TextBox_Nickname"
                    Grid.Row="3"
                    Header="(선택) 닉네임"
                    KeyDown="EditorInput_KeyDown"
                    PlaceholderText="예시) 상재, 장사, 생시, etc..."
                    TabIndex="2"
                    Text="{x:Bind Editor.Nickname, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox
                    x:Name="TextBox_GroupName"
                    Grid.Row="4"
                    Header="(선택) 그룹 이름"
                    KeyDown="EditorInput_KeyDown"
                    PlaceholderText="예시) 나, 동생, 1, 2, 3, etc..."
                    TabIndex="3"
                    Text="{x:Bind Editor.GroupName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <StackPanel
                    Grid.Row="5"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        x:Name="Button_Save"
                        Click="Button_Save_Click"
                        Content="{x:Bind SaveButtonText, Mode=OneWay}"
                        IsEnabled="{x:Bind CanSave, Mode=OneWay}"
                        TabIndex="4"
                        Style="{StaticResource AccentButtonStyle}" />
                    <Button
                        x:Name="Button_Reset"
                        Click="Button_Reset_Click"
                        Content="입력 초기화"
                        IsTabStop="False"
                        Visibility="{x:Bind ResetButtonVisibility, Mode=OneWay}" />
                    <Button
                        x:Name="Button_CancelEdit"
                        Click="Button_CancelEdit_Click"
                        Content="수정 취소"
                        IsTabStop="False"
                        Visibility="{x:Bind CancelEditButtonVisibility, Mode=OneWay}" />
                </StackPanel>
                <RichTextBlock
                    Grid.Row="6"
                    VerticalAlignment="Bottom"
                    FontStyle="Italic">
                    <Paragraph>
                        본 프로그램은 비밀번호를 Windows 자격 증명 관리자를 통해 로컬에 저장하며, 운영체제의 보안 메커니즘에 의해 보호됩니다.
                    </Paragraph>
                    <Paragraph>또한, 계정 정보를 로컬을 제외한 개발자 서버 또는 제3자에게 별도로 제공 및 저장하지 않습니다.</Paragraph>
                    <Paragraph>예외로 자동 로그인을 위해 아이디 및 비밀번호가 거상 공식 홈페이지를 통해 전송될 수 있습니다.</Paragraph>
                    <Paragraph>
                        <Hyperlink Click="PrivacyPolicyHyperlink_Click">개인정보취급방침</Hyperlink>
                        을 통해 자세한 정보를 확인하실 수 있습니다.</Paragraph>
                </RichTextBlock>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
