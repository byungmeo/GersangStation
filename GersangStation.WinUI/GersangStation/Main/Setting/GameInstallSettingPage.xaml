<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="GersangStation.Main.Setting.GameInstallSettingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:GersangStation.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:GersangStation.Main.Setting"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Disabled"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <SelectorBar
            x:Name="SelectorBar_Server"
            Grid.Row="0"
            IsEnabled="{x:Bind IsNotBusy, Mode=OneWay}"
            SelectionChanged="SelectorBar_Server_SelectionChanged">
            <SelectorBarItem x:Name="SelectorBarItem_Live" Text="본섭" />
            <SelectorBarItem x:Name="SelectorBarItem_Test" Text="테섭" />
            <SelectorBarItem x:Name="SelectorBarItem_RnD" Text="천라섭" />
        </SelectorBar>

        <Border
            Grid.Row="0"
            Height="1"
            Margin="0,10,0,0"
            VerticalAlignment="Bottom"
            Background="{ThemeResource ControlStrokeColorDefaultBrush}" />

        <Grid Grid.Row="1" Padding="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <controls:ValidatedTextBox
                x:Name="TextBox_InstallPath"
                Grid.Row="0"
                Header="메인 클라이언트 설치경로"
                InputIsEnabled="{x:Bind IsNotBusy, Mode=OneWay}"
                PlaceholderText="예시) C:\Games"
                TextChanged="TextBox_InstallPath_TextChanged">
                <controls:ValidatedTextBox.InputRowRightContent>
                    <Button
                        x:Name="Button_InstallPath_PickFolder"
                        Margin="8,0,0,0"
                        Click="Button_InstallPath_PickFolder_Click"
                        Content="..."
                        IsEnabled="{x:Bind IsNotBusy, Mode=OneWay}"
                        Style="{StaticResource AccentButtonStyle}" />
                </controls:ValidatedTextBox.InputRowRightContent>
            </controls:ValidatedTextBox>
            <TextBlock
                x:Name="TextBlock_InstallPath"
                Grid.Row="1"
                Text="C:\Games\AKInteractive\Gersang" />
            <Button
                x:Name="Button_Install"
                Grid.Row="2"
                Margin="0,20,0,0"
                Click="Button_Install_Click"
                Content="설치 시작"
                IsEnabled="{x:Bind IsInstallStartEnabled, Mode=OneWay}"
                Style="{StaticResource AccentButtonStyle}" />
            <Grid
                Grid.Row="3"
                Margin="50,0,50,0"
                HorizontalAlignment="Stretch"
                Visibility="{x:Bind InstallProgressVisibility, Mode=OneWay}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ProgressBar
                    Grid.Row="0"
                    Grid.Column="0"
                    Height="8"
                    HorizontalAlignment="Stretch"
                    Maximum="{x:Bind ProgressMaximum, Mode=OneWay}"
                    Value="{x:Bind ProgressValue, Mode=OneWay}" />

                <Button
                    x:Name="Button_InstallStop"
                    Grid.Row="0"
                    Grid.Column="1"
                    Click="Button_InstallStop_Click"
                    IsEnabled="{x:Bind IsDownloading, Mode=OneWay}"
                    Style="{ThemeResource AlternateCloseButtonStyle}"
                    Visibility="{x:Bind InstallCancelVisibility, Mode=OneWay}">
                    <Button.Content>
                        <FontIcon Glyph="&#xE711;" />
                    </Button.Content>
                </Button>

                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    HorizontalAlignment="Center"
                    Text="{x:Bind ProgressText, Mode=OneWay}" />
            </Grid>
        </Grid>
    </Grid>
</Page>
