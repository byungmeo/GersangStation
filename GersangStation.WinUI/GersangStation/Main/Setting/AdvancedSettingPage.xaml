<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="GersangStation.Main.Setting.AdvancedSettingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:GersangStation.Main.Setting"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Disabled"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="16" Spacing="12">
            <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="고급 설정" />

            <Border
                Height="1"
                Margin="0,6"
                Background="{ThemeResource CardStrokeColorDefaultBrush}" />

            <StackPanel
                MaxWidth="520"
                HorizontalAlignment="Left"
                Spacing="12">
                <!--#region ClipMouse-->
                <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="마우스 가두기" />
                <TextBlock
                    Opacity="0.72"
                    Text="윈도우 디스플레이 설정이 고배율(125%, 150% 등)인 경우 게임 밖으로 마우스가 벗어나지 않도록 개선합니다."
                    TextWrapping="WrapWholeWords" />
                <ToggleSwitch
                    x:Name="ToggleSwitch_MouseConfinement"
                    OffContent="비활성화"
                    OnContent="활성화"
                    Toggled="ToggleSwitch_MouseConfinement_Toggled" />
                <StackPanel
                    x:Name="Panel_ClipMouseAdminWarning"
                    Orientation="Horizontal"
                    Spacing="8"
                    Visibility="Collapsed">
                    <TextBlock
                        VerticalAlignment="Top"
                        Foreground="#C42B1C"
                        Text="이 기능을 사용하려면 관리자 권한이 필요합니다."
                        TextWrapping="WrapWholeWords" />
                    <HyperlinkButton
                        Padding="0"
                        VerticalAlignment="Top"
                        Click="HyperlinkButton_ClipMouseAdminHelp_Click"
                        Content="도움말 보기" />
                </StackPanel>
                <Border
                    x:Name="Border_ClipMouseHotkeyPanel"
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="Collapsed">
                    <StackPanel Spacing="12">
                        <TextBlock FontWeight="SemiBold" Text="마우스 탈출 단축키" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="현재 단축키는 Alt 고정입니다. Alt를 누르는 동안 마우스 가두기가 일시적으로 해제됩니다."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
                <!--#endregion ClipMouse-->

                <Border
                    Height="1"
                    Margin="0,6"
                    Background="{ThemeResource CardStrokeColorDefaultBrush}" />

                <!--#region WindowSwitch-->
                <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="창 전환" />
                <TextBlock
                    Opacity="0.72"
                    Text="게임을 2개 이상 실행한 상태에서 Alt + `를 누르면 1번, 2번, 3번 실행 버튼 순서대로 게임 창을 위로 순환시킵니다."
                    TextWrapping="WrapWholeWords" />
                <ToggleSwitch
                    x:Name="ToggleSwitch_WindowSwitching"
                    OffContent="비활성화"
                    OnContent="활성화"
                    Toggled="ToggleSwitch_WindowSwitching_Toggled" />
                <StackPanel
                    x:Name="Panel_WindowSwitchAdminWarning"
                    Orientation="Horizontal"
                    Spacing="8"
                    Visibility="Collapsed">
                    <TextBlock
                        VerticalAlignment="Top"
                        Foreground="#C42B1C"
                        Text="이 기능을 사용하려면 관리자 권한이 필요합니다."
                        TextWrapping="WrapWholeWords" />
                    <HyperlinkButton
                        Padding="0"
                        VerticalAlignment="Top"
                        Click="HyperlinkButton_ClipMouseAdminHelp_Click"
                        Content="도움말 보기" />
                </StackPanel>
                <Border
                    x:Name="Border_WindowSwitchHotkeyPanel"
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="Collapsed">
                    <StackPanel Spacing="12">
                        <TextBlock FontWeight="SemiBold" Text="창 전환 단축키" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="현재 단축키는 Alt + ` 고정입니다. 창 탐색 중에는 마우스 가두기가 잠시 해제되고, 좌클릭으로 창을 결정하면 탐색이 끝납니다."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
                <!--#endregion WindowSwitch-->

                <Border
                    Height="1"
                    Margin="0,6"
                    Background="{ThemeResource CardStrokeColorDefaultBrush}" />

                <!--#region Developer Mode-->
                <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="개발자 모드" />
                <TextBlock
                    Opacity="0.72"
                    Text="디버깅이나 테스트용 기능이 필요할 때만 개발자 모드를 켜세요."
                    TextWrapping="WrapWholeWords" />
                <ToggleSwitch
                    x:Name="ToggleSwitch_DeveloperTool"
                    OffContent="비활성화"
                    OnContent="활성화"
                    Toggled="ToggleSwitch_DeveloperTool_Toggled" />
                <!--#endregion Developer Mode-->
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
