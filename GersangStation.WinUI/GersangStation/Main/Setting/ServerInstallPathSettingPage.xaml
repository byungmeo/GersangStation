<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="GersangStation.Main.Setting.ServerInstallPathSettingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:GersangStation.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:GersangStation.Main.Setting"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=local:ServerInstallPathSettingPage}"
    NavigationCacheMode="Disabled"
    mc:Ignorable="d">

    <Grid Margin="10,10,10,10" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--#region Column 0-->
        <controls:ValidatedTextBox
            x:Name="TextBox_Path1"
            Grid.Row="0"
            Grid.Column="0"
            Header="메인 클라이언트 설치경로"
            PlaceholderText="예시) C:\AKInteractive\Gersang"
            Text="{x:Bind ClientSettings.InstallPath, Mode=TwoWay}"
            TextChanged="TextBox_InstallPath_TextChanged">
            <controls:ValidatedTextBox.InputRowRightContent>
                <StackPanel Orientation="Horizontal">
                    <Button
                        x:Name="Button_Path1_PickFolder"
                        Click="Button_Path_PickFolder_Click"
                        Content="..."
                        Margin="0,0,8,0"
                        Style="{StaticResource AccentButtonStyle}" />
                    <Button
                        x:Name="Button_AutoFind"
                        Click="Button_AutoFind_Click"
                        Content="자동 찾기" />
                    <TeachingTip
                        x:Name="TeachingTip_Button_AutoFind"
                        Title="This is the title"
                        IsLightDismissEnabled="True"
                        PlacementMargin="20"
                        PreferredPlacement="Auto"
                        Subtitle="And this is the subtitle" />
                </StackPanel>

            </controls:ValidatedTextBox.InputRowRightContent>
        </controls:ValidatedTextBox>

        <Expander
            x:Name="Expander_MultiClient"
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            IsExpanded="{x:Bind ClientSettings.UseMultiClient, Mode=OneTime}">
            <Expander.Header>
                <ToggleSwitch
                    x:Name="ToggleSwitch_UseMultiClient"
                    IsOn="{x:Bind ClientSettings.UseMultiClient, Mode=TwoWay}"
                    OffContent="다클라 미사용"
                    OnContent="다클라 사용"
                    Toggled="ToggleSwitch_UseMultiClient_Toggled" />
            </Expander.Header>
            <Expander.Content>
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel
                        Grid.Row="0"
                        Grid.ColumnSpan="2"
                        Orientation="Vertical">
                        <InfoBar
                            Title="효율적인 다클라 생성방식이란?"
                            IsOpen="{x:Bind ShowSymbolInfoBar, Mode=OneWay}"
                            Message="윈도우의 '바로가기'와 유사한 '심볼릭링크' 방식을 활용하여 다클라 용량 및 생성 속도를 약 90% 절감할 수 있습니다." />
                        <InfoBar
                            Title="효율적인 다클라 생성방식을 사용할 수 없습니다."
                            IsOpen="{x:Bind ShowSymbolErrorBar, Mode=OneWay}"
                            Message="드라이브의 파일 시스템이 NTFS인 경우에만 사용 가능합니다."
                            Severity="Error">
                            <InfoBar.ActionButton>
                                <Button
                                    x:Name="Button_SymbolErrorAction"
                                    Click="Button_SymbolErrorAction_Click"
                                    Content="해결 방법" />
                            </InfoBar.ActionButton>
                        </InfoBar>
                        <CheckBox
                            x:Name="CheckBox_UseSymbol"
                            Grid.Row="0"
                            Grid.ColumnSpan="2"
                            Content="효율적인 다클라 생성방식 사용"
                            IsChecked="{x:Bind ClientSettings.UseSymbol, Mode=TwoWay}"
                            IsEnabled="{x:Bind CanUseSymbol, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="1"
                        Grid.ColumnSpan="2"
                        Orientation="Horizontal"
                        Spacing="10">
                        <Button
                            x:Name="Button_CreateMultiClient"
                            Grid.Row="0"
                            Grid.ColumnSpan="2"
                            Click="Button_CreateMultiClient_Click"
                            Content="다클라 생성"
                            Style="{ThemeResource AccentButtonStyle}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="아직 다클라를 생성하지 않으셨나요?" />
                    </StackPanel>

                    <controls:ValidatedTextBox
                        x:Name="TextBox_Path2"
                        Grid.Row="2"
                        Grid.Column="1"
                        Header="(선택) 2클라 설치경로"
                        InputIsEnabled="{x:Bind TextBox_Path2_IsEnabled, Mode=OneWay}"
                        PlaceholderText="예시) C:\AKInteractive\Gersang2"
                        Text="{x:Bind ClientSettings.Client2Path, Mode=TwoWay}"
                        TextChanged="TextBox_InstallPath_TextChanged">
                        <controls:ValidatedTextBox.InputRowLeftContent>
                            <CheckBox
                                x:Name="CheckBox_UseClient2"
                                MinWidth="35"
                                MaxWidth="35"
                                VerticalAlignment="Bottom"
                                IsChecked="{x:Bind ClientSettings.UseClient2, Mode=TwoWay}"
                                IsEnabled="{x:Bind ClientSettings.UseMultiClient, Mode=OneWay}" />
                        </controls:ValidatedTextBox.InputRowLeftContent>
                        <controls:ValidatedTextBox.InputRowRightContent>
                            <Button
                                x:Name="Button_Path2_PickFolder"
                                Click="Button_Path_PickFolder_Click"
                                Content="..."
                                IsEnabled="{x:Bind TextBox_Path2_IsEnabled, Mode=OneWay}"
                                Style="{StaticResource AccentButtonStyle}" />
                        </controls:ValidatedTextBox.InputRowRightContent>
                    </controls:ValidatedTextBox>

                    <controls:ValidatedTextBox
                        x:Name="TextBox_Path3"
                        Grid.Row="3"
                        Grid.Column="1"
                        Header="(선택) 3클라 설치경로"
                        InputIsEnabled="{x:Bind TextBox_Path3_IsEnabled, Mode=OneWay}"
                        PlaceholderText="예시) C:\AKInteractive\Gersang3"
                        Text="{x:Bind ClientSettings.Client3Path, Mode=TwoWay}"
                        TextChanged="TextBox_InstallPath_TextChanged">
                        <controls:ValidatedTextBox.InputRowLeftContent>
                            <CheckBox
                                x:Name="CheckBox_UseClient3"
                                MinWidth="35"
                                MaxWidth="35"
                                VerticalAlignment="Bottom"
                                IsChecked="{x:Bind ClientSettings.UseClient3, Mode=TwoWay}"
                                IsEnabled="{x:Bind ClientSettings.UseMultiClient, Mode=OneWay}" />
                        </controls:ValidatedTextBox.InputRowLeftContent>
                        <controls:ValidatedTextBox.InputRowRightContent>
                            <Button
                                x:Name="Button_Path3_PickFolder"
                                Click="Button_Path_PickFolder_Click"
                                Content="..."
                                IsEnabled="{x:Bind TextBox_Path3_IsEnabled, Mode=OneWay}"
                                Style="{StaticResource AccentButtonStyle}" />
                        </controls:ValidatedTextBox.InputRowRightContent>
                    </controls:ValidatedTextBox>
                </Grid>
            </Expander.Content>
        </Expander>
        <Button
            x:Name="Button_Save"
            Grid.Row="2"
            HorizontalAlignment="Right"
            Click="Button_Save_Click"
            Content="저장"
            IsEnabled="{x:Bind IsDirty, Mode=OneWay}"
            Style="{ThemeResource AccentButtonStyle}" />
        <!--#endregion Column 0-->

        <!--#region Column 1-->
        <Grid />
        <!--#endregion Column 1-->
    </Grid>
</Page>
