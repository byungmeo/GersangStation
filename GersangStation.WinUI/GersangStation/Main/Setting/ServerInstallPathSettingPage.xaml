<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="GersangStation.Main.Setting.ServerInstallPathSettingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:GersangStation.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:GersangStation.Main.Setting"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=local:ServerInstallPathSettingPage}"
    NavigationCacheMode="Disabled"
    mc:Ignorable="d">

    <ScrollView>
        <Grid Margin="10,10,10,10" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--#region Column 0-->
            <controls:ValidatedTextBox
                x:Name="TextBox_Path1"
                Grid.Row="0"
                Header="메인 클라이언트 설치경로"
                PlaceholderText="예시) C:\AKInteractive\Gersang"
                Text="{x:Bind ClientSettings.InstallPath, Mode=TwoWay}"
                TextChanged="TextBox_InstallPath_TextChanged">
                <controls:ValidatedTextBox.InputRowRightContent>
                    <Button
                        x:Name="Button_Path1_PickFolder"
                        Margin="8,0,0,0"
                        Click="Button_Path_PickFolder_Click"
                        Content="..."
                        Style="{StaticResource AccentButtonStyle}" />
                </controls:ValidatedTextBox.InputRowRightContent>
            </controls:ValidatedTextBox>

            <StackPanel
                Grid.Row="1"
                Orientation="Horizontal"
                Spacing="8"
                Visibility="{x:Bind InstallGuideVisibility, Mode=OneWay}">
                <TextBlock VerticalAlignment="Center" Text="아직 게임을 설치하지 않으셨나요?" />
                <HyperlinkButton
                    Padding="0"
                    Click="HyperlinkButton_InstallGame_Click"
                    Content="설치하기" />
            </StackPanel>

            <StackPanel Grid.Row="2" Spacing="12">
                <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="클라이언트 사용 방식" />
                <TextBlock
                    Opacity="0.72"
                    Text="메인 클라이언트만 사용할지, 다클라 설정을 함께 사용할지 선택해 주세요."
                    TextWrapping="WrapWholeWords" />
                <RadioButtons SelectedIndex="{x:Bind ClientUsageModeIndex, Mode=TwoWay}">
                    <x:String>메인 클라이언트만 사용</x:String>
                    <x:String>다클라 사용</x:String>
                </RadioButtons>

                <StackPanel Spacing="8" Visibility="{x:Bind MultiClientSettingsVisibility, Mode=OneWay}">
                    <InfoBar
                        Title="효율적인 다클라 생성방식이란?"
                        IsOpen="{x:Bind ShowSymbolInfoBar, Mode=OneWay}"
                        Message="윈도우의 '바로가기'와 유사한 '심볼릭링크' 방식을 활용하여 다클라 용량 및 생성 속도를 약 99% 절감할 수 있습니다. 미체크 시 다클라 생성을 지원하지 않습니다." />
                    <InfoBar
                        Title="효율적인 다클라 생성방식을 사용할 수 없습니다."
                        IsOpen="{x:Bind ShowSymbolErrorBar, Mode=OneWay}"
                        Message="드라이브의 파일 시스템이 NTFS인 경우에만 사용 가능합니다."
                        Severity="Error">
                        <InfoBar.ActionButton>
                            <HyperlinkButton
                                x:Name="Button_SymbolErrorAction"
                                Click="Button_SymbolErrorAction_Click"
                                Content="해결 방법" />
                        </InfoBar.ActionButton>
                    </InfoBar>
                    <CheckBox
                        x:Name="CheckBox_UseSymbol"
                        Content="(권장) 효율적인 다클라 생성방식 사용"
                        IsChecked="{x:Bind ClientSettings.UseSymbol, Mode=TwoWay}"
                        IsEnabled="{x:Bind CanUseSymbol, Mode=OneWay}" />

                    <CheckBox
                        x:Name="CheckBox_UseClient2"
                        Content="2클라 사용"
                        IsChecked="{x:Bind ClientSettings.UseClient2, Mode=TwoWay}"
                        IsEnabled="{x:Bind ClientSettings.UseMultiClient, Mode=OneWay}" />

                    <CheckBox
                        x:Name="CheckBox_UseClient3"
                        Content="3클라 사용"
                        IsChecked="{x:Bind ClientSettings.UseClient3, Mode=TwoWay}"
                        IsEnabled="{x:Bind ClientSettings.UseMultiClient, Mode=OneWay}" />

                    <RichTextBlock Margin="0,0,0,8">
                        <Paragraph>안정적인 다클라 기능 제공을 위해 다클라 경로는 위와 같이 고정됩니다. 이미 다클라가 있으신 분들은 삭제 후 재생성 또는 이름을 동일하게 변경해주세요.</Paragraph>
                    </RichTextBlock>

                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8"
                        Visibility="{x:Bind ClientSettings.UseSymbol, Mode=OneWay}">
                        <Button
                            x:Name="Button_CreateMultiClient"
                            Click="Button_CreateMultiClient_Click"
                            Content="다클라 생성"
                            IsEnabled="{x:Bind TextBox_Path1.IsValid, Mode=OneWay}"
                            Style="{ThemeResource AccentButtonStyle}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="아직 다클라를 생성하지 않으셨나요?" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <Button
                x:Name="Button_Save"
                Grid.Row="3"
                HorizontalAlignment="Right"
                Click="Button_Save_Click"
                Content="저장"
                IsEnabled="{x:Bind IsDirty, Mode=OneWay}"
                Style="{ThemeResource AccentButtonStyle}" />
            <!--#endregion Column 0-->

            <TeachingTip
                x:Name="TeachingTip_General"
                Title="Title"
                Grid.RowSpan="3"
                CloseButtonContent="네, 확인했습니다."
                IsLightDismissEnabled="True"
                PlacementMargin="20"
                PreferredPlacement="Auto"
                Subtitle="Subtitle" />
        </Grid>
    </ScrollView>
</Page>
