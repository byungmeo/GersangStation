<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="GersangStation.Main.Setting.BehaviorSettingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:GersangStation.Main.Setting"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=local:BehaviorSettingPage}"
    Loaded="BehaviorSettingPage_Loaded"
    mc:Ignorable="d">

    <Grid>
        <ScrollViewer>
            <StackPanel Padding="24,24,24,40" Spacing="20">
                <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="동작 설정" />

                <Border
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="윈도우 시작 자동 실행" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Windows에 로그인할 때 거상스테이션을 자동으로 실행합니다."
                            TextWrapping="WrapWholeWords" />
                        <ToggleSwitch
                            x:Name="ToggleSwitch_StartupRegistration"
                            Header="윈도우 시작 시 프로그램 자동 실행"
                            OffContent="해제"
                            OnContent="등록"
                            Toggled="ToggleSwitch_StartupRegistration_Toggled" />
                        <ToggleSwitch
                            x:Name="ToggleSwitch_StartupRegistrationRunAsAdministrator"
                            Header="자동 실행 시 관리자 권한으로 실행"
                            OffContent="일반 권한"
                            OnContent="관리자 권한"
                            Toggled="ToggleSwitch_StartupRegistrationRunAsAdministrator_Toggled" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="이 옵션을 켜면 일반 시작 프로그램 대신 작업 스케줄러를 사용합니다. 등록 또는 해제 시 Windows 관리자 권한 승인이 필요할 수 있습니다."
                            TextWrapping="WrapWholeWords" />
                        <Button
                            x:Name="Button_CreateAdminLaunchDesktopShortcut"
                            Click="Button_CreateAdminLaunchDesktopShortcut_Click"
                            Style="{ThemeResource AccentButtonStyle}"
                            Content="바탕화면에 관리자 실행 바로가기 만들기"
                            HorizontalAlignment="Left" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="{x:Bind StartupRegistrationMessage, Mode=OneWay}"
                            TextWrapping="WrapWholeWords"
                            Visibility="{x:Bind StartupRegistrationMessageVisibility, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="창 최소화 기본 동작" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="앱 타이틀바의 최소화(-) 버튼을 눌렀을 때 동작을 설정합니다."
                            TextWrapping="WrapWholeWords" />
                        <RadioButtons SelectedIndex="{x:Bind MinimizeBehaviorIndex, Mode=TwoWay}">
                            <x:String>시스템 트레이에 숨기기 (기본값)</x:String>
                            <x:String>작업 표시줄에 숨기기</x:String>
                        </RadioButtons>
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="트레이에 숨긴 뒤에는 트레이 아이콘을 더블 클릭해서 다시 열 수 있습니다."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
                <Border
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="창 닫기 기본 동작" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="앱 타이틀바의 닫기(X) 버튼을 눌렀을 때 동작을 설정합니다."
                            TextWrapping="WrapWholeWords" />
                        <RadioButtons SelectedIndex="{x:Bind CloseBehaviorIndex, Mode=TwoWay}">
                            <x:String>앱 종료(기본값)</x:String>
                            <x:String>시스템 트레이에 숨기기</x:String>
                        </RadioButtons>
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="트레이에 숨길 경우 트레이 아이콘을 우클릭 한 뒤 종료 버튼을 눌러 종료할 수 있습니다."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
