<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="GersangStation.Main.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:GersangStation.Main"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="GersangStation"
    mc:Ignorable="d">

    <Grid x:Name="Root">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Grid.ColumnSpan="3"
            Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}" />

        <!--  TitleBar Left Header  -->
        <ImageIcon
            Width="30"
            Height="30"
            Margin="17,0,10,0"
            Source="/Assets/Icons/Square44x44Logo.png" />

        <!--  SelectorBar  -->
        <SelectorBar
            x:Name="MainSelectorBar"
            Grid.Row="0"
            Grid.Column="1"
            SelectionChanged="MainSelectorBar_SelectionChanged">

            <!--  메인 스테이션 바  -->
            <SelectorBarItem
                Icon="Home"
                IsSelected="True"
                Text="메인" />

            <!--  웹뷰 바  -->
            <SelectorBarItem
                x:Name="SelectorBarItem_Browser"
                Icon="World"
                Text="브라우저" />

            <!--  플래너 바  -->
            <SelectorBarItem
                Icon="Calendar"
                IsEnabled="False"
                Text="플래너" />

            <!--  환경설정 바  -->
            <SelectorBarItem
                x:Name="SelectorBarItem_Setting"
                Icon="Setting"
                Text="설정" />
        </SelectorBar>
        <Border
            Grid.Row="1"
            Grid.ColumnSpan="2"
            Height="1"
            Margin="0,0,0,5"
            VerticalAlignment="Bottom"
            Background="{ThemeResource ControlStrokeColorDefaultBrush}" />
        <!--  Frame  -->
        <Frame
            x:Name="ContentFrame"
            Grid.Row="2"
            Grid.ColumnSpan="2"
            IsNavigationStackEnabled="False" />
    </Grid>
</Window>
