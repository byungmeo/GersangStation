<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="GersangStation.Main.WebViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:GersangStation.Main"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="using:Core.Models"
    xmlns:service="using:GersangStation.Services"
    d:DataContext="{d:DesignInstance Type=service:WebViewManager}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button
                    x:Name="Button_WebPreview_Back"
                    Grid.Column="0"
                    Width="40"
                    Height="40"
                    Click="Button_WebPreview_Back_Click"
                    IsEnabled="{x:Bind _webviewManager.CanGoBack, Mode=OneWay}"
                    Style="{StaticResource SubtleButtonStyle}">
                    <Viewbox Margin="2,0,2,0" Stretch="Uniform">
                        <SymbolIcon Symbol="Back" />
                    </Viewbox>
                </Button>
                <Button
                    x:Name="Button_WebPreview_Forward"
                    Grid.Column="1"
                    Width="40"
                    Height="40"
                    Click="Button_WebPreview_Forward_Click"
                    IsEnabled="{x:Bind _webviewManager.CanGoForward, Mode=OneWay}"
                    Style="{StaticResource SubtleButtonStyle}">
                    <Viewbox Margin="2,0,2,0" Stretch="Uniform">
                        <SymbolIcon Symbol="Forward" />
                    </Viewbox>
                </Button>
                <Button
                    x:Name="Button_WebPreview_Refresh"
                    Grid.Column="2"
                    Width="40"
                    Height="40"
                    Click="Button_WebPreview_Refresh_Click"
                    Style="{StaticResource SubtleButtonStyle}"
                    ToolTipService.ToolTip="새로고침">
                    <Viewbox Margin="2,0,2,0" Stretch="Uniform">
                        <SymbolIcon Symbol="Refresh" />
                    </Viewbox>
                </Button>
                <Button
                    x:Name="Button_WebPreview_Home"
                    Grid.Column="3"
                    Width="40"
                    Height="40"
                    Click="Button_WebPreview_Home_Click"
                    Style="{StaticResource SubtleButtonStyle}"
                    ToolTipService.ToolTip="거상공홈으로 이동">
                    <Viewbox Margin="1,0,1,0" Stretch="Uniform">
                        <SymbolIcon Symbol="Home" />
                    </Viewbox>
                </Button>
                <ComboBox
                    x:Name="ComboBox_Account"
                    Grid.Column="4"
                    Width="200"
                    VerticalAlignment="Center"
                    Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                    DisplayMemberPath="Nickname"
                    ItemsSource="{x:Bind Accounts, Mode=OneWay}"
                    PlaceholderText="미로그인 상태"
                    SelectedItem="{x:Bind SelectedAccount, Mode=TwoWay}"
                    SelectionChanged="ComboBox_Account_SelectionChanged"
                    ToolTipService.ToolTip="로그인 계정 선택 및 로그인 현황" />
                <TextBox
                    x:Name="TextBox_Search"
                    Grid.Column="5"
                    Margin="10,6,0,6"
                    Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    GotFocus="TextBox_Search_GotFocus"
                    KeyDown="TextBox_Search_KeyDown"
                    LostFocus="TextBox_Search_LostFocus"
                    PlaceholderText="주소 또는 검색어 입력" />
                <Button
                    x:Name="Button_Favorite"
                    Grid.Column="6"
                    Width="40"
                    Height="40"
                    Click="Button_Favorite_Click"
                    Style="{StaticResource SubtleButtonStyle}"
                    ToolTipService.ToolTip="{x:Bind FavoriteButtonToolTip, Mode=OneWay}">
                    <Viewbox Margin="0" Stretch="Uniform">
                        <FontIcon Glyph="{x:Bind FavoriteButtonGlyph, Mode=OneWay}" />
                    </Viewbox>
                </Button>
                <Button
                    x:Name="Button_WebPreview_LaunchExternal"
                    Grid.Column="7"
                    Width="40"
                    Height="40"
                    Margin="0,0,2,0"
                    Click="Button_WebPreview_LaunchExternal_Click"
                    Style="{StaticResource SubtleButtonStyle}"
                    ToolTipService.ToolTip="외부 브라우저로 열기">
                    <Viewbox Margin="0" Stretch="Uniform">
                        <FontIcon Glyph="&#xE774;" />
                    </Viewbox>
                </Button>
            </Grid>

            <Grid
                Grid.Row="1"
                Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                Visibility="{x:Bind FavoritesVisibility, Mode=OneWay}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <ScrollViewer
                    Grid.Row="0"
                    Margin="10,0,10,0"
                    HorizontalScrollBarVisibility="Auto"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Disabled"
                    VerticalScrollMode="Disabled">
                    <ItemsControl ItemsSource="{x:Bind Favorites, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="model:BrowserFavorite">
                                <Button
                                    Padding="5,4"
                                    Click="FavoriteItem_Click"
                                    Style="{StaticResource SubtleButtonStyle}"
                                    Tag="{x:Bind}">
                                    <Button.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem
                                                Click="FavoriteRename_Click"
                                                Tag="{x:Bind}"
                                                Text="이름 변경" />
                                            <MenuFlyoutItem
                                                Click="FavoriteDelete_Click"
                                                Tag="{x:Bind}"
                                                Text="삭제" />
                                        </MenuFlyout>
                                    </Button.ContextFlyout>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Grid Width="16" Height="16">
                                            <Border Background="{ThemeResource ControlFillColorSecondaryBrush}" CornerRadius="4">
                                                <FontIcon
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="10"
                                                    Glyph="&#xE774;" />
                                            </Border>
                                            <Image Width="16" Height="16">
                                                <Image.Source>
                                                    <BitmapImage UriSource="{x:Bind DisplayFaviconUrl, Mode=OneTime}" />
                                                </Image.Source>
                                            </Image>
                                        </Grid>
                                        <TextBlock
                                            MaxWidth="180"
                                            Text="{x:Bind Name}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <ToolTipService.ToolTip>
                                        <ToolTip Content="{x:Bind Url}" />
                                    </ToolTipService.ToolTip>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <Border
                    Grid.Row="1"
                    Height="1"
                    Margin="0,10,0,0"
                    VerticalAlignment="Bottom"
                    Background="{ThemeResource ControlStrokeColorDefaultBrush}" />
            </Grid>

            <WebView2
                x:Name="WebView"
                Grid.Row="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Visibility="Visible" />
        </Grid>
    </Grid>
</Page>
